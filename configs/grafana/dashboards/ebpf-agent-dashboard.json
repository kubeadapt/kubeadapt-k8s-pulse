    {
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "description": "Shows whether the eBPF program loaded successfully (1 = LOADED, 0 = FAILED)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "❌ FAILED"
                },
                "1": {
                  "color": "green",
                  "text": "✅ LOADED"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 101,
      "options": {
        "colorMode": "background",
